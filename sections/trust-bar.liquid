{{ 'section-trust-bar.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #TrustBar-{{ section.id }} {
    --trust-bar-items: {{ section.blocks.size }};
  }
{%- endstyle -%}

<div
  id="TrustBar-{{ section.id }}"
  class="trust-bar color-{{ section.settings.color_scheme }} gradient{% if section.settings.show_dividers %} trust-bar--dividers{% endif %}"
>
  <ul
    class="trust-bar__list page-width section-{{ section.id }}-padding list-unstyled"
    role="list"
  >
    {%- for block in section.blocks -%}
      <li class="trust-bar__item" {{ block.shopify_attributes }}>
        {%- liquid
          assign has_image = false
          assign has_icon = false
          if block.settings.image != blank
            assign has_image = true
          elsif block.settings.icon != 'none'
            assign has_icon = true
          endif
        -%}

        {%- if has_image or has_icon -%}
          <div class="trust-bar__icon-wrap" aria-hidden="true">
            {%- if has_image -%}
              {{
                block.settings.image
                | image_url: width: 96
                | image_tag:
                  widths: '48, 72, 96',
                  loading: 'lazy',
                  class: 'trust-bar__image'
              }}
            {%- else -%}
              <span class="trust-bar__svg-wrap svg-wrapper">
                {%- assign icon_file = block.settings.icon | replace: '_', '-' | prepend: 'icon-' | append: '.svg' -%}
                {{ icon_file | inline_asset_content }}
              </span>
            {%- endif -%}
          </div>
        {%- endif -%}

        <div class="trust-bar__content">
          {%- if block.settings.heading != blank -%}
            <p class="trust-bar__heading">{{ block.settings.heading | escape }}</p>
          {%- endif -%}
          {%- if block.settings.description != blank -%}
            <p class="trust-bar__description">{{ block.settings.description | escape }}</p>
          {%- endif -%}
        </div>
      </li>
    {%- endfor -%}
  </ul>
</div>

{% schema %}
{
  "name": "Trust Bar",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "show_dividers",
      "label": "Show dividers between items",
      "default": true
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom icon image",
          "info": "Upload a custom icon. When set, overrides the icon selector below."
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "info": "Used when no custom image is uploaded above.",
          "options": [
            {
              "value": "none",
              "label": "None"
            },
            {
              "value": "box",
              "label": "Box"
            },
            {
              "value": "chat_bubble",
              "label": "Chat bubble"
            },
            {
              "value": "check_mark",
              "label": "Check mark"
            },
            {
              "value": "lock",
              "label": "Lock"
            },
            {
              "value": "padlock",
              "label": "Padlock"
            },
            {
              "value": "price_tag",
              "label": "Price tag"
            },
            {
              "value": "recycle",
              "label": "Recycle"
            },
            {
              "value": "return",
              "label": "Return"
            },
            {
              "value": "star",
              "label": "Star"
            },
            {
              "value": "stopwatch",
              "label": "Stopwatch"
            },
            {
              "value": "truck",
              "label": "Truck"
            }
          ],
          "default": "truck"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Schneller Versand"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Lieferung in 1–3 Werktagen"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Bar",
      "settings": {
        "show_dividers": true,
        "color_scheme": "scheme-2",
        "padding_top": 20,
        "padding_bottom": 20
      },
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "icon": "truck",
            "heading": "Schneller Versand",
            "description": "Lieferung in 1–3 Werktagen"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "lock",
            "heading": "Sichere Zahlung",
            "description": "SSL-verschlüsselt & DSGVO-konform"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "return",
            "heading": "30 Tage Rückgabe",
            "description": "Kostenlose Rücksendung"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "price_tag",
            "heading": "Flexible Zahlung",
            "description": "PayPal, Kreditkarte, SEPA"
          }
        }
      ]
    }
  ]
}
{% endschema %}

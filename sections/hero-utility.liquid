{{ 'section-hero-utility.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #HeroUtility-{{ section.id }} .hero-utility__inner {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<div
  id="HeroUtility-{{ section.id }}"
  class="hero-utility hero-utility--align-{{ section.settings.content_alignment }}{% if section.settings.background_image != blank %} hero-utility--has-image{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}"
>
  {%- if section.settings.background_image != blank -%}
    <div class="hero-utility__media">
      {{
        section.settings.background_image
        | image_url: width: 3840
        | image_tag:
          sizes: '100vw',
          widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840',
          fetchpriority: 'high',
          loading: 'eager'
      }}
      <div
        class="hero-utility__overlay"
        style="background-color: rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }});"
        aria-hidden="true"
      ></div>
    </div>
  {%- endif -%}

  <div class="hero-utility__inner page-width">
    {%- if section.settings.heading != blank -%}
      <h1 class="hero-utility__heading {{ section.settings.heading_size }}">
        {{ section.settings.heading }}
      </h1>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="hero-utility__subheading">
        {{ section.settings.subheading | escape }}
      </p>
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
      <div class="hero-utility__cta">
        <a
          {% if section.settings.button_link == blank %}
            role="link" aria-disabled="true"
          {% else %}
            href="{{ section.settings.button_link }}"
          {% endif %}
          class="button button--primary"
        >
          {{- section.settings.button_label | escape -}}
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Hero Utility",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Technik & Haushalt – alles aus einer Hand"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        },
        {
          "value": "hxl",
          "label": "Extra large"
        }
      ],
      "default": "h1"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Über 1.000 Produkte: Batterien, Werkzeuge, Elektrokomponenten und mehr."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Jetzt entdecken"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 10,
      "unit": "%",
      "label": "Image overlay opacity",
      "default": 50
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Hero Utility",
      "settings": {
        "heading": "Technik & Haushalt – alles aus einer Hand",
        "subheading": "Über 1.000 Produkte: Batterien, Werkzeuge, Elektrokomponenten und mehr.",
        "button_label": "Jetzt entdecken",
        "overlay_opacity": 50,
        "content_alignment": "center",
        "padding_top": 40,
        "padding_bottom": 40
      }
    }
  ]
}
{% endschema %}

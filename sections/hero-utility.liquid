{{ 'section-hero-utility.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign fetch_priority = 'auto'
  assign loading_strategy = 'lazy'
  if section.index == 1
    assign fetch_priority = 'high'
    assign loading_strategy = 'eager'
  endif
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #HeroUtility-{{ section.id }} {
    --hero-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  }
{%- endstyle -%}

<div
  id="HeroUtility-{{ section.id }}"
  class="hero-utility color-{{ section.settings.color_scheme }} gradient hero-utility--align-{{ section.settings.content_alignment }}{% if section.settings.background_image != blank %} hero-utility--has-image{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}"
>
  {%- if section.settings.background_image != blank -%}
    <div class="hero-utility__media">
      {{
        section.settings.background_image
        | image_url: width: 3840
        | image_tag:
          sizes: '100vw',
          widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840',
          fetchpriority: fetch_priority,
          loading: loading_strategy
      }}
      <div class="hero-utility__overlay" aria-hidden="true"></div>
    </div>
  {%- endif -%}

  <div class="hero-utility__inner page-width section-{{ section.id }}-padding">
    {%- if section.settings.heading != blank -%}
      {%- if section.settings.heading_level == 'h2' -%}
        <h2 class="hero-utility__heading {{ section.settings.heading_size }}">
          {{ section.settings.heading }}
        </h2>
      {%- else -%}
        <h1 class="hero-utility__heading {{ section.settings.heading_size }}">
          {{ section.settings.heading }}
        </h1>
      {%- endif -%}
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="hero-utility__subheading">
        {{ section.settings.subheading | escape }}
      </p>
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
      <div class="hero-utility__cta">
        <a
          {% if section.settings.button_link == blank %}
            role="link" aria-disabled="true"
          {% else %}
            href="{{ section.settings.button_link }}"
          {% endif %}
          class="button button--primary"
        >
          {{- section.settings.button_label | escape -}}
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Hero Utility",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Technik & Haushalt – alles aus einer Hand"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        },
        {
          "value": "hxl",
          "label": "Extra large"
        }
      ],
      "default": "h1"
    },
    {
      "type": "select",
      "id": "heading_level",
      "label": "Heading HTML element",
      "info": "Use H1 only once per page. Choose H2 when another H1 already exists on the page.",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        }
      ],
      "default": "h1"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Über 1.000 Produkte: Batterien, Werkzeuge, Elektrokomponenten und mehr."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Jetzt entdecken"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 10,
      "unit": "%",
      "label": "Image overlay opacity",
      "info": "Only applies when a background image is set.",
      "default": 50
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "info": "Controls background and text color when no background image is used.",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Hero Utility",
      "settings": {
        "heading": "Technik & Haushalt – alles aus einer Hand",
        "subheading": "Über 1.000 Produkte: Batterien, Werkzeuge, Elektrokomponenten und mehr.",
        "button_label": "Jetzt entdecken",
        "overlay_opacity": 50,
        "content_alignment": "center",
        "padding_top": 40,
        "padding_bottom": 40
      }
    }
  ]
}
{% endschema %}
